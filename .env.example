# =============================================================================
# Portfolio App — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# --- Supabase (Backing Service) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Resend Email (Backing Service) ---
RESEND_API_KEY="re_your_api_key"

# --- Contact Configuration ---
# Email address that receives contact form submissions
CONTACT_TO_EMAIL="you@example.com"
# Sender address shown in notification emails (must be verified with Resend)
CONTACT_FROM_EMAIL="Portfolio Contact <onboarding@resend.dev>"

# --- Rate Limiting ---
# Maximum contact form submissions per email address per hour
RATE_LIMIT_MAX_PER_HOUR="5"
